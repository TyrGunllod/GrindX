# ==========================================
# Banco de Dados (SQL Server — somente leitura)
# ==========================================
# Formato pyodbc: servidor,porta
DB_SERVER=XXX.XXX.XXX.XXX,XXXXX
DB_DATABASE=sua_base
DB_USERNAME=seu_user_name
DB_PASSWORD=seu_password
DB_DRIVER=ODBC Driver 17 for SQL Server

# ==========================================
# JWT / Segurança
# Deve ser IDÊNTICA à SECRET_KEY da api-postgres
# para que os tokens emitidos lá sejam aceitos aqui
# ==========================================
SECRET_KEY=troque-por-uma-chave-secreta-forte-com-pelo-menos-32-caracteres

# ==========================================
# Configurações da Aplicação
# ==========================================
APP_NAME="GrindX API SQL Server"
APP_VERSION=0.1.0
DEBUG=false
ENABLE_CACHE=false
LOG_LEVEL=INFO

# ==========================================
# CORS (Formato JSON)
# Ao acessar de outro computador, adicione o IP:
# Ex: http://192.168.1.100:5500
# ==========================================
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
