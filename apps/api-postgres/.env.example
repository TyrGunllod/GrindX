# ==========================================
# Banco de Dados (PostgreSQL)
# Usa psycopg3: postgresql+psycopg://
# ==========================================
DATABASE_URL=postgresql+psycopg://postgres:sua_senha@localhost:5432/grindx

# ==========================================
# JWT / Segurança
# ==========================================
SECRET_KEY=test-secret-key-for-unit-tests-only-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# Configurações da Aplicação
# ==========================================
APP_NAME="GrindX API Postgres"
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================
# CORS (Formato JSON)
# Se vazio em dev, usa defaults: localhost + DEV_NETWORK_IP
# ==========================================
# Se vazio em dev, usa defaults: localhost + DEV_NETWORK_IP
CORS_ORIGINS=

# ==========================================
# IP da rede local para acesso externo em dev
# Adiciona automaticamente ao CORS fallback e ao CSP connect-src
# Ex: 192.168.0.62
# ==========================================
DEV_NETWORK_IP=192.168.0.62

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ==========================================
# SMTP / Email (edite com credenciais reais)
# ==========================================
SMTP_HOST=127.0.0.1
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=false
EMAIL_FROM=admin@grindx.local
EMAIL_FROM_NAME=GrindX Administrador
