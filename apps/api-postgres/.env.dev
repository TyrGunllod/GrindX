# ==========================================
# Banco de Dados (PostgreSQL)
# Usa psycopg3: postgresql+psycopg://
# ==========================================
DATABASE_URL=postgresql+psycopg://postgres:sua_senha@localhost:5432/grindx

# ==========================================
# JWT / Segurança
# ==========================================
SECRET_KEY=test-secret-key-for-unit-tests-only-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# Configurações da Aplicação
# ==========================================
APP_NAME="GrindX API Postgres"
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================
# CORS (Formato JSON)
# Ao acessar de outro computador, adicione o IP:
# Ex: http://192.168.1.100:8101
# ==========================================
CORS_ORIGINS=["http://localhost:8101","http://127.0.0.1:8101"]
DEV_NETWORK_IP=192.168.0.62

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
