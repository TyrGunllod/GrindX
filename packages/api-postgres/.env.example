# ==========================================
# Banco de Dados (PostgreSQL)
# Usa psycopg3: postgresql+psycopg://
# Alternativa psycopg2: postgresql+psycopg2:// ou postgresql://
# ==========================================
DATABASE_URL=postgresql+psycopg://erp_user:sua_senha_aqui@localhost:5432/erp_local

# ==========================================
# JWT / Segurança
# ==========================================
SECRET_KEY=troque-por-uma-chave-secreta-forte-com-pelo-menos-32-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# CORS
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==========================================
# Aplicação
# ==========================================
APP_NAME=ERP API Postgres
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
