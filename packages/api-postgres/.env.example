# ==========================================
# Banco de Dados (PostgreSQL)
# Usa psycopg3: postgresql+psycopg://
# Alternativa psycopg2: postgresql+psycopg2:// ou postgresql://
# ==========================================
DATABASE_URL=postgresql+psycopg://postgres:sua_senha_aqui@localhost:5432/sgidb

# ==========================================
# JWT / Segurança
# ==========================================
SECRET_KEY=test-secret-key-for-unit-tests-only-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# AConfigurações da Aplicação
# ==========================================
APP_NAME="ERP API Postgres"
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================
# CORS (Formato JSON)
# ==========================================
CORS_ORIGINS=["*"]

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
