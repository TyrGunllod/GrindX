# ==========================================
# Banco de Dados (PostgreSQL)
# Usa psycopg3: postgresql+psycopg://
# ==========================================
DATABASE_URL=postgresql+psycopg://postgres:inter2018@localhost:5432/grindx

# ==========================================
# JWT / Segurança
# ==========================================
SECRET_KEY=l13fqQV90pr45erksgVcp3p3Srr0qfP8r0v74bF3iyg=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# Configurações da Aplicação
# ==========================================
APP_NAME="GrindX API Postgres"
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================
# CORS (Formato JSON)
# Ao acessar de outro computador, adicione o IP:
# Ex: http://192.168.1.100:5500
# ==========================================
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
