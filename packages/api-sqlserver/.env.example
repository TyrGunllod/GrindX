# ==========================================
# Banco de Dados (SQL Server — somente leitura)
# ==========================================
DATABASE_URL=mssql+pymssql://usuario:sua_senha_aqui@servidor.database.windows.net:1433/erp_cloud

# ==========================================
# JWT / Segurança (mesma chave da api-postgres)
# ==========================================
SECRET_KEY=troque-por-uma-chave-secreta-forte-com-pelo-menos-32-caracteres

# ==========================================
# CORS
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==========================================
# Aplicação
# ==========================================
APP_NAME=ERP API SQL Server
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
