# ==========================================
# Banco de Dados (SQL Server — somente leitura)
# ==========================================
# Exemplo para pyodbc: servidor,porta (ex: 181.41.161.145,10371)
# Exemplo para pymssql: servidor (a porta será tratada internamente)
DB_SERVER=181.41.161.145,10371
DB_DATABASE=C5MS0I_204354_PR_PD
DB_USERNAME=LEITURAPROD
DB_PASSWORD=sua_senha_aqui
# Use "ODBC Driver 17 for SQL Server" ou similar para pyodbc. 
# Deixe vazio ou mude para usar pymssql fallback.
DB_DRIVER=ODBC Driver 17 for SQL Server

# ==========================================
# JWT / Segurança (mesma chave da api-postgres)
# ==========================================
SECRET_KEY=troque-por-uma-chave-secreta-forte-com-pelo-menos-32-caracteres

# ==========================================
# Configurações da Aplicação
# ==========================================
APP_NAME="ERP API SQL Server"
APP_VERSION=0.1.0
DEBUG=false
ENABLE_CACHE=false
LOG_LEVEL=INFO

# ==========================================
# CORS (Formato JSON)
# ==========================================
CORS_ORIGINS=["*"]

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
