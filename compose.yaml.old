networks:
  interozone:
    driver: bridge

services:

  frontend:
    image: docker.io/library/nginx
    container_name: grindx-frontend
    ports:
      - "0.0.0.0:8101:80"
      - "0.0.0.0:8001:8001"
      - "0.0.0.0:8002:8002"
    volumes:
      # Modificado: Seus arquivos do site e configurações organizados na pasta de volumes
      - /home/alex/Containers/volumes/frontend_www:/usr/share/nginx/html:z
      - /home/alex/Containers/volumes/frontend_config/nginx.conf:/etc/nginx/conf.d/default.conf:ro,z
    networks:
      - interozone
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:80/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 5s
    restart: unless-stopped
    
  api-sqlserver:
    image: grindx/api-sqlserver:dev
    container_name: grindx-api-sqlserver
    user: "1001:1001"
    network_mode: "container:grindx-frontend"
    env_file: ./apps/api-sqlserver/.env
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8001/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    restart: unless-stopped
    environment:
      - PYTHONPATH=/app:/app/packages
    volumes:
      # Modificado: O pacote compartilhado agora fica centralizado na sua pasta de volumes
      #- /home/alex/Containers/volumes/shared_packages:/app/shared:z
      - /home/alex/Apps/GrindX/packages:/app/packages:z
      - /home/alex/Apps/GrindX/apps/api-postgres/.env:/app/.env:z


  api-postgres:
    image: grindx/api-postgres:dev
    container_name: grindx-api-postgres
    user: "1001:1001"
    network_mode: "container:grindx-frontend"
    env_file: ./apps/api-postgres/.env
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8002/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    restart: unless-stopped
    environment:
      - PYTHONPATH=/app:/app/packages
    volumes:
      # Modificado: Aponta para a mesma pasta compartilhada que a outra API usa
      #- /home/alex/Containers/volumes/shared_packages:/app/shared:z
      - /home/alex/Apps/GrindX/packages:/app/packages:z
      - /home/alex/Apps/GrindX/apps/api-sqlserver/.env:/app/.env:z
      - /home/alex/Containers/volumes/api_uploads:/app/static/uploads:z
